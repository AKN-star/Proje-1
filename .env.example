# Neon Postgres bağlantı dizesi (Vercel prod/preview ortamları).
# Boş bırakılırsa dev PGlite kullanır (.pglite/ dizini, gitignore'da);
# testler her zaman in-memory PGlite kurar — bu değişkene ihtiyaç duymaz.
DATABASE_URL=

# Auth.js v5 (Faz 1) — `npx auth secret` ile üretilir.
AUTH_SECRET=

# Resend (Faz 1: magic-link e-postaları; Faz 6: rozet bildirimleri).
# Dev'de boşsa magic-link konsola loglanır.
RESEND_API_KEY=

# Anthropic API (Faz 3: moderasyon, Faz 5: çeviri).
ANTHROPIC_API_KEY=
